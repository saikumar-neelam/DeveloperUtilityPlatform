# Copy this to .env.production on the EC2 instance and fill in all values.
# Never commit .env.production to git.

PORT=8080

# AWS RDS PostgreSQL — get the endpoint from RDS console
POSTGRES_DSN=postgres://webhookdb:<PASSWORD>@<RDS_ENDPOINT>:5432/webhookdb?sslmode=require

# NATS runs on the same EC2 instance via Docker Compose
NATS_URL=nats://nats:4222

# AWS S3
S3_BUCKET=your-bucket-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_ENDPOINT=

# Vercel frontend URL — used for CORS
FRONTEND_URL=https://your-app.vercel.app
