# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/webhookdb?sslmode=disable

# ── NATS ─────────────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Storage ───────────────────────────────────────────────────────────────────
S3_BUCKET=webhook-payloads
AWS_REGION=us-east-1

# Local MinIO (comment out when using real AWS S3)
S3_ENDPOINT=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Real AWS S3 (uncomment and remove S3_ENDPOINT above)
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
