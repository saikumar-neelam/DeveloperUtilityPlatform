# Set these in Vercel → Project Settings → Environment Variables

# EC2 backend — used by Next.js server (rewrites, route handlers)
BACKEND_URL=http://<EC2_PUBLIC_IP_OR_DOMAIN>:8080

# EC2 backend — exposed to the browser for direct SSE connection
NEXT_PUBLIC_BACKEND_URL=http://<EC2_PUBLIC_IP_OR_DOMAIN>:8080
